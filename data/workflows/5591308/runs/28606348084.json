{"id":28606348084,"name":"Run api tests","node_id":"WFR_kwLOA_1uaM8AAAAGqRI7NA","head_branch":"DHIS2-21120_master","head_sha":"25c3050d1907654aa51ddceff60e097641e3035d","path":".github/workflows/run-api-tests.yml","run_number":50855,"run_attempt":1,"event":"pull_request","display_title":"feat: JSON auth/updatePassword endpoint, remove legacy account/password [DHIS2-21120]","status":"completed","conclusion":"success","workflow_id":5591308,"check_suite_id":77294130604,"check_suite_node_id":"CS_kwDOA_1uaM8AAAAR_xbVrA","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/28606348084","pull_requests":[{"id":3979962604,"number":24355,"url":"https://api.github.com/repos/dhis2/dhis2-core/pulls/24355","head":{"ref":"DHIS2-21120_master","sha":"3fa151973fd1bf5cbf172e8045e306e69c621d12","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}},"base":{"ref":"master","sha":"a4665bc2092b99c00785ebd7f8ce75a68b62c9cc","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}}}],"created_at":"2026-07-02T16:40:16Z","updated_at":"2026-07-02T16:53:15Z","run_started_at":"2026-07-02T16:40:16Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/77294130604","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/28606348084/rerun","head_commit":{"message":"feat: JSON auth/updatePassword endpoint, remove legacy account/password [DHIS2-21120]\n\nAdd POST /api/auth/updatePassword on UserAccountController as the JSON,\nauth/*-family endpoint for changing an expired password from the new Login\napp, and remove the legacy form-param POST /api/account/password it replaces.\n\nThe new endpoint mirrors the auth/passwordReset flow: unauthenticated (the\ncaller is not logged in), self-guarding (only proceeds for an expired account\nwhose current password is supplied correctly), reuses the shared password\npolicy validation, and returns WebMessage JSON. It deliberately does not\nestablish a session; once the password is changed the account is no longer\nexpired, so the frontend calls the existing auth/login. It also fixes a\nlatent null-deref in the legacy handler (unknown username) and avoids\nusername enumeration by returning one generic message.\n\nThe legacy AccountController.updatePassword (and its now-unused PasswordManager\nfield) is removed, along with the account/password permitAll allowlist entry,\nthe AccountPasswordPermitAllTest, and the orphaned expired.js that was its only\nin-repo caller (dead code from the pre-2.41 struts login, referenced by no\npage). The separate GET /api/account/password password-validation endpoint is\nuntouched.\n\nThis is a breaking change for any external client still posting to\naccount/password; it should not be backported to 2.41-2.43, where the legacy\nstruts expired page may still exist.\n\nCo-Authored-By: Claude Opus 4.8 (1M context) \u003cnoreply@anthropic.com\u003e","author":{"name":"Morten Svanaes","email":"msvanaes@dhis2.org"},"id":"25c3050d1907654aa51ddceff60e097641e3035d","tree_id":"3c7069e20b72bb221468e3c6c17b37a84a7e5c16","timestamp":"2026-07-02T16:39:24Z","committer":{"name":"Morten Svanaes","email":"msvanaes@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url"