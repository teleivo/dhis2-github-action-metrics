{"id":29894585598,"name":"Run api tests","node_id":"WFR_kwLOA_1uaM8AAAAG9dss_g","head_branch":"fix/DHIS2-21872-propertytransformer-iswritable-gate","head_sha":"ffcf953c5431170b3a8468935e6e126a976a5ff0","path":".github/workflows/run-api-tests.yml","run_number":51291,"run_attempt":1,"event":"pull_request","display_title":"fix: detect @PropertyTransformer on read-only derived properties [DHIS2-21872]","status":"completed","conclusion":"success","workflow_id":5591308,"check_suite_id":80974275229,"check_suite_node_id":"CS_kwDOA_1uaM8AAAAS2nFinQ","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/29894585598","created_at":"2026-07-22T05:43:19Z","updated_at":"2026-07-22T05:54:28Z","run_started_at":"2026-07-22T05:43:19Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/80974275229","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29894585598/rerun","head_commit":{"message":"fix: detect @PropertyTransformer on read-only derived properties [DHIS2-21872]\n\nPropertyPropertyIntrospector.updatePropertyTypes() only read the\n@PropertyTransformer annotation inside the isWritable() branch. A\nproperty whose getter is annotated but has no matching setter (e.g.\nUserRole.getUsers(), computed from the separately-named `members`\nfield) is read-only, so its annotation was silently dropped and\nProperty.hasPropertyTransformer() returned false at runtime even\nthough the annotation is present in source.\n\nMove the annotation read outside the writability gate, since whether\na property is serialized via a custom transformer is orthogonal to\nwhether it can be written to.\n\nFound while live-validating DHIS2-21856/PR #24519: with that fix\nalone, GET /api/userRoles/{id}?fields=users[*] against an\n83,385-member role still took 139.7s / ~583k queries because\nhasPropertyTransformer() never saw UserRole.users' annotation. With\nthis fix applied, the same request drops to 5.76s.","author":{"name":"Jason Pickering","email":"jason@dhis2.org"},"id":"ffcf953c5431170b3a8468935e6e126a976a5ff0","tree_id":"c4a75eaee8a6ce48106ea3fd32c3bcd3a518c39d","timestamp":"2026-07-22T05:42:36Z","committer":{"name":"Jason Pickering","email":"jason@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_