{"id":29731538323,"name":"Run api tests","node_id":"WFR_kwLOA_1uaM8AAAAG7CNFkw","head_branch":"worktree-tracker-perf-409-diagnosis","head_sha":"61aeb52aaa7fe63bed6c0c45d821e82192abb4d6","path":".github/workflows/run-api-tests.yml","run_number":51227,"run_attempt":1,"event":"pull_request","display_title":"chore(perf): capture failed-request bodies in tracker perf test","status":"completed","conclusion":"success","workflow_id":5591308,"check_suite_id":80505737723,"check_suite_node_id":"CS_kwDOA_1uaM8AAAASvoQR-w","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/29731538323","pull_requests":[{"id":4089883362,"number":24507,"url":"https://api.github.com/repos/dhis2/dhis2-core/pulls/24507","head":{"ref":"worktree-tracker-perf-409-diagnosis","sha":"373fd7123753eb03c1c89660b51e93eb8f79c9de","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}},"base":{"ref":"master","sha":"ec1292282cde5471d62c1377dc32e206b2d73bf4","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}}}],"created_at":"2026-07-20T09:27:54Z","updated_at":"2026-07-20T09:38:45Z","run_started_at":"2026-07-20T09:27:54Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/80505737723","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29731538323/rerun","head_commit":{"message":"chore(perf): capture failed-request bodies in tracker perf test\n\nThe \"Performance tests compare\" workflow intermittently fails with a storm\nof 409 CONFLICT responses on every `POST /api/tracker` import (and, as a\ndownstream effect, empty exports). The failure is environmental/flaky - it\nhas hit both the baseline and the candidate side - but it has been\nundiagnosable because Gatling's simulation.log records only the status code,\nnot the response body, and the harness does not capture DHIS2 server logs by\ndefault. So the actual import error (the 409 payload) is lost.\n\nEnable Gatling's `io.gatling.http.engine.response` logger at DEBUG, which\ndumps the full request + response (including body) for FAILED requests only.\nGreen runs have no failures, so this is silent there and does not perturb the\nperf measurement. Override via -DGATLING_RESPONSE_LOG_LEVEL. This makes the\nnext CI occurrence self-diagnosing.\n\nAlso add scripts/reproduce-tracker-409.sh: runs the LOAD profile in a loop\nagainst a chosen image, preserving each iteration's full console output and\nstopping on the first failure so the captured 409 body can be inspected.\n\nCo-Authored-By: Claude Opus 4.8 (1M context) \u003cnoreply@anthropic.com\u003e","author":{"name":"Enrico","email":"enrico@dhis2.org"},"id":"61aeb52aaa7fe63bed6c0c45d821e82192abb4d6","tree_id":"104f2f543be0acfbec40a2e3a3c9abb9a010dcb8","timestamp":"2026-07-20T09:27:27Z","committer":{"name":"Enrico","email":"enrico@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_u