{"id":29901004839,"name":"Run api tests","node_id":"WFR_kwLOA_1uaM8AAAAG9j0gJw","head_branch":"fix/DHIS2-21872-propertytransformer-iswritable-gate","head_sha":"bf33cb29274ed46a879267d1da411784547fab02","path":".github/workflows/run-api-tests.yml","run_number":51293,"run_attempt":1,"event":"pull_request","display_title":"fix: detect @PropertyTransformer on read-only derived properties [DHIS2-21872]","status":"completed","conclusion":"success","workflow_id":5591308,"check_suite_id":80991932322,"check_suite_node_id":"CS_kwDOA_1uaM8AAAAS237Pog","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/29901004839","created_at":"2026-07-22T07:39:31Z","updated_at":"2026-07-22T07:50:50Z","run_started_at":"2026-07-22T07:39:31Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/80991932322","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29901004839/rerun","head_commit":{"message":"fix: apply @Property annotation regardless of writability too [DHIS2-21872]\n\nPer review feedback from @jbee: initFromPropertyAnnotation() was also\ngated behind isWritable(), but most of @Property's attributes (type\noverride, required/persisted/owner flags, persistedAs aliasing)\ndescribe the property itself and apply equally to read-only\nproperties or aliases, not just writable ones.\n\nSnapshot writability before calling initFromPropertyAnnotation(),\nsince that call can itself flip it via access = READ_ONLY/WRITE_ONLY,\nand range/min-max defaults should still be judged against the\npre-annotation writability (matches existing behavior for e.g.\nAttribute.getObjectTypes(), which has a real setter overridden to\nread-only via the annotation).\n\nAdded regression coverage: a read-only property now picks up\npersistedAs() (previously silently ignored), and a writable property\nwhose annotation overrides it to read-only still gets range/min-max\ndefaults applied (unchanged behavior).","author":{"name":"Jason Pickering","email":"jason@dhis2.org"},"id":"bf33cb29274ed46a879267d1da411784547fab02","tree_id":"d3a922d667eeee3c1c3896aaaf70127358f39324","timestamp":"2026-07-22T07:39:22Z","committer":{"name":"Jason Pickering","email":"jason@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_url":"