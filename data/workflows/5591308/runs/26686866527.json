{"id":26686866527,"name":"Run api tests","node_id":"WFR_kwLOA_1uaM8AAAAGNqlEXw","head_branch":"ci/build-once-test-many","head_sha":"022dd39917d33516088a7dba40a1c8872642d709","path":".github/workflows/run-api-tests.yml","run_number":50117,"run_attempt":1,"event":"pull_request","display_title":"ci: build the reactor once and reuse it across the test jobs","status":"completed","conclusion":"failure","workflow_id":5591308,"check_suite_id":71533301516,"check_suite_node_id":"CS_kwDOA_1uaM8AAAAQp7ePDA","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/26686866527","created_at":"2026-05-30T14:53:53Z","updated_at":"2026-05-30T15:06:38Z","run_started_at":"2026-05-30T14:53:53Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/71533301516","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26686866527/rerun","head_commit":{"message":"ci: build the reactor once and reuse it across the test jobs\n\nEvery test job (unit, integration shards, integration-h2) used to run\n`mvn clean test` on the whole ~39-module reactor, so the same full compile\nwas paid 6× per run — the dominant cost of the test workflow.\n\nAdd a `build` job that compiles and installs the reactor a single time and\npublishes the compiled classes; the test jobs restore those and run with\n`-Dmaven.main.skip=true`, skipping the main compile while running the normal\n`mvn test` lifecycle (so surefire and JaCoCo coverage are produced exactly as\nbefore).\n\nThe single build is made incremental across runs by the Apache Maven Build\nCache extension: a PR touching a few modules recompiles only those. All cache\nmachinery is confined to the `build` job and materialized on the runner only —\nit is never committed, so local builds and the other jobs load no extension and\nbehave exactly as before.\n\nCo-Authored-By: Claude Opus 4.8 (1M context) \u003cnoreply@anthropic.com\u003e","author":{"name":"Stian Sandvold","email":"stian@dhis2.org"},"id":"022dd39917d33516088a7dba40a1c8872642d709","tree_id":"ff8aebdb3e33125c335b53899fe7e24f9a9094a4","timestamp":"2026-05-30T14:44:28Z","committer":{"name":"Stian Sandvold","email":"stian@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_url":"https://api.github.com/repos/d