) and the generic\naudit pipeline has both sinks (logger, database) off for tracker with\ndefault configuration. The full per-entity JMS pipeline (entity state\nserialization, JSON serialization, Artemis publish/consume) was running\nonly to discard every message at the consumer.\n\nMove the audit matrix check into the Hibernate listeners before building\nthe Audit object. This skips the expensive createAuditEntry() (schema\nlookup, entity state iteration) when the matrix is disabled, not just\nthe JMS pipeline.\n\nUsers who need tracker audit can enable it explicitly via\naudit.tracker=CREATE;UPDATE;DELETE in dhis.conf.","author":{"name":"teleivo","email":"teleivo@users.noreply.github.com"},"id":"841a77dd71933766faf9fa53ded0f4007c6412cf","tree_id":"b5800735779b665ea01df9e7d068ae96f76943cd","timestamp":"2026-04-09T15:18:41Z","committer":{"name":"teleivo","email":"teleivo@users.noreply.github.com"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_na