ibernate listeners before building the\nAudit object. Previously the check only happened inside\nAuditManager.send(), after the expensive createAuditEntry() work (schema\nlookup, entity state serialization). This benefits all scopes.\n\nAdditional cleanups:\n- Simplify audit matrix from Map\u003cAuditType, Boolean\u003e to Set\u003cAuditType\u003e\n- Fail on invalid audit type config instead of silently ignoring\n- Handle DISABLED as an explicit token (was working by accident)\n- Trim whitespace in audit type config values\n- Fix test config using wrong separator (CREATE_UPDATE_DELETE instead of\n  CREATE;UPDATE;DELETE)","author":{"name":"teleivo","email":"teleivo@users.noreply.github.com"},"id":"4e008adfd78168c628c4ea1aadf13908aded5e12","tree_id":"07a0d8479821512a4111fb41a8a052f51ddc9a68","timestamp":"2026-04-10T09:19:19Z","committer":{"name":"teleivo","email":"teleivo@users.noreply.github.com"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/5591308","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_nam