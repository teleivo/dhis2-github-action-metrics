er never saves).\n\nSame decision flow, gates, and OIDC rebuild as the removed filter; tests\nported to load-through-repository semantics plus laziness and caching\ncases.","author":{"name":"Morten Svanaes","email":"msvanaes@dhis2.org"},"id":"470479fa773a5f7a62f903452354a585b5d5f017","tree_id":"9db583d8dbf09f7f58f3235790a3a98b54f074c7","timestamp":"2026-07-18T19:21:00Z","committer":{"name":"Morten Svanaes","email":"msvanaes@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/10954","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_url":"https://api.github.com/repos/dhis2/dhis2-core/{archive_format}{/ref}","assignees_url":"https://api.github.com/repos/dhis2/dhis2-core/assignees{/user}","blobs_url":"https://api.github.com/repos/dhis2/dhis2-core/git/blo