{"id":29315992173,"name":"Test","node_id":"WFR_kwLOA_1uaM8AAAAG016KbQ","head_branch":"feat/doris-continuous-analytics","head_sha":"d60e333bc71d35da2a922b57e2fdbc348b6048f6","path":".github/workflows/run-tests.yml","run_number":54703,"run_attempt":1,"event":"pull_request","display_title":"feat: continuous analytics (lastYears=0) support for Doris","status":"completed","conclusion":"success","workflow_id":10954,"check_suite_id":79337923176,"check_suite_node_id":"CS_kwDOA_1uaM8AAAASeOiiaA","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/29315992173","pull_requests":[{"id":4050031827,"number":24440,"url":"https://api.github.com/repos/dhis2/dhis2-core/pulls/24440","head":{"ref":"feat/doris-continuous-analytics","sha":"fcc1b5e830bf39f41c7567cff223042680b09dad","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}},"base":{"ref":"master","sha":"2ff99213778150690d70415ee3c8610470aa7e16","repo":{"id":66940520,"name":"dhis2-core","url":"https://api.github.com/repos/dhis2/dhis2-core"}}}],"created_at":"2026-07-14T07:51:49Z","updated_at":"2026-07-14T08:00:01Z","run_started_at":"2026-07-14T07:51:49Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/79337923176","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/29315992173/rerun","head_commit":{"message":"fix: DorisSqlBuilder.tableExists() checks wrong schema, breaking continuous-analytics history preservation\n\ntableExists() filtered on t.table_schema = 'public', but native Doris\nanalytics tables live in whatever database the connection is on (e.g.\n'dhis2'), not 'public' ('public' is only correct for the federated\nPostgres catalog). This meant tableExists() always returned false for\nreal Doris tables, so swapTable()'s skipMasterTable was always false,\nso every continuous (lastYears=0) run silently replaced the entire\nmain analytics table with just the latest-window data instead of\ninserting into the existing table - destroying history.\n\nFound via a live manual test against a real Doris instance: triggered\nlastYears=0, and confirmed the main table's row count and partition\nhistory matched exactly what a full replace (not a merge) would\nproduce. Fixed by using database() instead of the hardcoded schema\nname, which correctly resolves to the connection's actual database.\nRe-verified live after the fix: history preserved, create/update/delete\nall correctly reflected, \"skip master table: true\" confirmed in logs.\n\nCo-Authored-By: Claude Sonnet 5 \u003cnoreply@anthropic.com\u003e","author":{"name":"Jason Pickering","email":"jason@dhis2.org"},"id":"d60e333bc71d35da2a922b57e2fdbc348b6048f6","tree_id":"51e7f1108377662ff747eb3a5590634d57c4d61b","timestamp":"2026-07-14T07:51:28Z","committer":{"name":"Jason Pickering","email":"jason@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/10954","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gist