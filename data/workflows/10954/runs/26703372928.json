{"id":26703372928,"name":"Test","node_id":"WFR_kwLOA_1uaM8AAAAGN6UigA","head_branch":"fix/micrometer-1.16.5-prometheus-align","head_sha":"71bae2d89fc61e389ffab597f5d20e2f3bf05d15","path":".github/workflows/run-tests.yml","run_number":53768,"run_attempt":1,"event":"pull_request","display_title":"chore(deps): bump micrometer to 1.16.5 and align prometheus-metrics-model","status":"completed","conclusion":"success","workflow_id":10954,"check_suite_id":71579143793,"check_suite_node_id":"CS_kwDOA_1uaM8AAAAQqnMOcQ","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/26703372928","created_at":"2026-05-31T04:37:26Z","updated_at":"2026-05-31T04:47:06Z","run_started_at":"2026-05-31T04:37:26Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/71579143793","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/26703372928/rerun","head_commit":{"message":"chore(deps): bump micrometer to 1.16.5 and align prometheus-metrics-model to 1.4.3\n\nmicrometer-registry-prometheus 1.16.5 depends on io.prometheus:prometheus-metrics-core\n1.4.3, and the io.prometheus client_java modules are released in lockstep (core declares\nprometheus-metrics-model at its own version). dhis-2/pom.xml pins prometheus-metrics-model\nexplicitly, so bumping micrometer alone leaves model behind at 1.3.1 while core moves to\n1.4.3.\n\nThat mismatch breaks the /api/metrics scrape endpoint at runtime:\n\n  java.lang.NoClassDefFoundError: io/prometheus/metrics/model/snapshots/SnapshotEscaper\n\n(SnapshotEscaper was introduced in the model 1.4.x line and is absent from 1.3.1.)\n\nBumping prometheus-metrics-model to 1.4.3 alongside micrometer re-aligns the train and\nkeeps the scrape endpoint and JVM metrics working.\n\nCo-Authored-By: Claude Opus 4.8 (1M context) \u003cnoreply@anthropic.com\u003e","author":{"name":"Stian Sandvold","email":"stian@dhis2.org"},"id":"71bae2d89fc61e389ffab597f5d20e2f3bf05d15","tree_id":"1f01de03ec73db5891981f8c6596d8484b805fb7","timestamp":"2026-05-31T04:37:06Z","committer":{"name":"Stian Sandvold","email":"stian@dhis2.org"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/10954","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_url":"https://api.github.com/repos/dhis2/dhis2-core/{archive_format}{/ref}","assignees_url":"https://api.github.com/repos