{"id":22429714574,"name":"Test","node_id":"WFR_kwLOA_1uaM8AAAAFOOpIjg","head_branch":"DHIS2-20921-orgunit-selected","head_sha":"72cc9d997110577dec9e062c6802a5816700bfa0","path":".github/workflows/run-tests.yml","run_number":50979,"run_attempt":1,"event":"pull_request","display_title":"perf: skip organisationunit join for orgUnitMode=SELECTED event queries DHIS2-20921","status":"completed","conclusion":"success","workflow_id":10954,"check_suite_id":58627069587,"check_suite_node_id":"CS_kwDOA_1uaM8AAAANpnIWkw","url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574","html_url":"https://github.com/dhis2/dhis2-core/actions/runs/22429714574","created_at":"2026-02-26T05:50:15Z","updated_at":"2026-02-26T06:06:13Z","run_started_at":"2026-02-26T05:50:15Z","jobs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574/jobs","logs_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574/logs","check_suite_url":"https://api.github.com/repos/dhis2/dhis2-core/check-suites/58627069587","artifacts_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574/artifacts","cancel_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574/cancel","rerun_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/runs/22429714574/rerun","head_commit":{"message":"perf: skip organisationunit join for orgUnitMode=SELECTED event queries DHIS2-20921\n\nFor orgUnitMode=SELECTED with a known program, filter directly on\ntrackedentityprogramowner.programid and organisationunitid instead of\njoining through the organisationunit table. This enables PostgreSQL to\nuse the (programid, organisationunitid) composite index on\ntrackedentityprogramowner as the driving access path.\n\nThe organisationunit table join constrained the optimizer to a backward\nevent PK scan that must probe every row when the selected org unit has\nfew or zero matches. With skewed data (50% of TEs at one org unit):\n\n  Events, zero-match org unit: 13,080ms -\u003e 0.03ms\n  Events, fat org unit (50%):  ~50ms    -\u003e 39ms\n  Events, small org unit:      ~45ms    -\u003e 8ms","author":{"name":"teleivo","email":"teleivo@users.noreply.github.com"},"id":"72cc9d997110577dec9e062c6802a5816700bfa0","tree_id":"17938d113adfcdbec3e67e15e1143d741b4c4b30","timestamp":"2026-02-26T05:49:49Z","committer":{"name":"teleivo","email":"teleivo@users.noreply.github.com"}},"workflow_url":"https://api.github.com/repos/dhis2/dhis2-core/actions/workflows/10954","repository":{"id":66940520,"node_id":"MDEwOlJlcG9zaXRvcnk2Njk0MDUyMA==","owner":{"login":"dhis2","id":1089987,"node_id":"MDEyOk9yZ2FuaXphdGlvbjEwODk5ODc=","avatar_url":"https://avatars.githubusercontent.com/u/1089987?v=4","html_url":"https://github.com/dhis2","gravatar_id":"","type":"Organization","site_admin":false,"url":"https://api.github.com/users/dhis2","events_url":"https://api.github.com/users/dhis2/events{/privacy}","following_url":"https://api.github.com/users/dhis2/following{/other_user}","followers_url":"https://api.github.com/users/dhis2/followers","gists_url":"https://api.github.com/users/dhis2/gists{/gist_id}","organizations_url":"https://api.github.com/users/dhis2/orgs","received_events_url":"https://api.github.com/users/dhis2/received_events","repos_url":"https://api.github.com/users/dhis2/repos","starred_url":"https://api.github.com/users/dhis2/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/dhis2/subscriptions"},"name":"dhis2-core","full_name":"dhis2/dhis2-core","description":"DHIS 2 Core. Written in Java. Contains the service layer and Web API.","html_url":"https://github.com/dhis2/dhis2-core","fork":false,"private":false,"url":"https://api.github.com/repos/dhis2/dhis2-core","archive_url":"https://api.github.com/repos/dhis2/dhis2-core/{archive_format}{/ref}","assignees_url":"https://api.github.com/repos/dhis2/dhis2-core/assignees{/user}","blobs_url":"https://api.github.com/repos/dhis2/dhis2-core/git/blobs{/sha}"